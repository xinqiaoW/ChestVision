# ═══════════════════════════════════════════════════════
# 胸片X光智能分析系统 — Git 忽略规则
# ═══════════════════════════════════════════════════════

# ── Python ──────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
.eggs/
dist/
build/

# ── 虚拟环境 ───────────────────────────────────────
.venv/
venv/
ENV/
env/

# ── 环境变量（含 API Key，绝对不能提交！）───────────
.env
.env.local

# ── IDE ────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── 模型权重文件（体积巨大，不上传 Git）──────────────
*.pt
*.pth
*.onnx
*.engine
*.weights
models/

# ── 训练输出（runs/）────────────────────────────────
runs/
yolo11x_train/

# ── 日志 ───────────────────────────────────────────
logs/
*.log

# ── 数据集（体积大，不上传 Git）───────────────────────
backend/datasets/
Xtest_data/
Xtrain-old/
# ── 文档/子项目（独立 Git 仓库）──────────────────────
XJTU-fxhd/
_.gitignore
# ── 运行时生成的文件 ────────────────────────────────
backend/storage/
.server-tools/
.run/

# ── 数据库 ─────────────────────────────────────────
*.db
*.sqlite
*.sqlite3

# ── Node.js / 前端 ──────────────────────────────────
node_modules/
frontend/dist/
.cache/
.output/

# ── Docker ─────────────────────────────────────────
.docker/

# ── Codex local work files ─────────────────────────
.codex_tmp_template/
_work/

# ── 测试覆盖率 ──────────────────────────────────────
htmlcov/
.coverage
.coverage.*
.pytest_cache/

# ── OS 文件 ────────────────────────────────────────
.DS_Store
Thumbs.db
