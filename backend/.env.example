# ChestVision Docker development environment
# Copy to backend/.env. scripts/setup-env.ps1 does this automatically.

# LLM providers are optional. Image detection works without these keys.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus

# Docker service addresses
DB_HOST=postgres
DB_PORT=5432
DB_NAME=chestx_agent
DB_USER=chestx_admin
DB_PASSWORD=chestx_admin
# 无 Docker/外部 PostgreSQL 时可使用：sqlite:////绝对路径/chestvision.db
DATABASE_URL_OVERRIDE=
REDIS_HOST=redis
REDIS_PORT=6379
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=chestx-agent-images
MINIO_SECURE=false

# Authentication and initial local administrator
JWT_SECRET_KEY=replace-with-a-long-random-value
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=admin123
DEFAULT_ADMIN_EMAIL=admin@chestvision.local
# 本地评审用医生档案；生产环境设为 false
SEED_DEMO_DOCTORS=true
DEFAULT_DEMO_DOCTOR_PASSWORD=doctor123

# Registration email verification (QQ Mail SMTP)
EMAIL_VERIFICATION_REQUIRED=true
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=ChestVision
SMTP_USE_SSL=true
SMTP_USE_STARTTLS=false
SMTP_TIMEOUT_SECONDS=15
EMAIL_CODE_EXPIRE_MINUTES=10
EMAIL_CODE_RESEND_SECONDS=60
EMAIL_CODE_MAX_ATTEMPTS=5
EMAIL_CODE_MAX_PER_EMAIL_PER_HOUR=5
EMAIL_CODE_MAX_PER_IP_PER_HOUR=20

# Application
APP_NAME=ChestVision
APP_VERSION=0.1.0
DEBUG=false
LOG_LEVEL=INFO

# ── CORS 配置 ────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080,http://localhost:5173,http://127.0.0.1:5173
# 服务器需要代理访问 GitHub/Qwen 时填写，例如 http://127.0.0.1:7697
CHESTVISION_PROXY_URL=

# ── 远程训练 OSS 配置 ───────────────────────────────────
# 服务端用于签发上传凭据、HeadObject 校验和读取训练产物。
# 可使用 OSS_* 独立凭证；如果留空，代码会尝试使用 ALIBABA_CLOUD_* 统一凭证。
OSS_ACCESS_KEY_ID=your-oss-access-key-id
OSS_ACCESS_KEY_SECRET=your-oss-access-key-secret
# 临时 STS 凭证才需要填写；长期 AccessKey 留空。
OSS_SECURITY_TOKEN=
# 普通 bucket 示例：https://oss-cn-beijing.aliyuncs.com
# 接入点 alias 场景下，这里仍填写地域 endpoint，不填写对象 URL 或预签名 URL。
OSS_ENDPOINT=https://oss-cn-beijing.aliyuncs.com
OSS_REGION=cn-beijing
# 普通 bucket 填 bucket 名；接入点场景填接入点 alias。
OSS_BUCKET=your-oss-bucket-or-access-point-alias
# 远程训练对象前缀，属于 bucket 内部路径。
REMOTE_TRAIN_OSS_PREFIX=remote-training
# 基础模型对象前缀，需预置 yolo11n.pt / yolo11s.pt 等基础权重。
REMOTE_TRAIN_BASE_MODEL_PREFIX=base_model
# 浏览器上传凭据有效期，单位秒；当前兼容 PUT 预签名 URL。
OSS_UPLOAD_URL_EXPIRES_SECONDS=900
# FC/EventBridge 调用后端内部回调接口的机器密钥；生产环境必须设置为随机长字符串。
REMOTE_TRAINING_CALLBACK_SECRET=change-me-to-a-random-secret

# ── 远程训练 PAI-DLC 配置 ───────────────────────────────
# 服务端用于创建、查询和停止 PAI-DLC 任务。
# 可使用 PAI_* 独立凭证；如果留空，代码会尝试使用 ALIBABA_CLOUD_* 统一凭证。
PAI_ACCESS_KEY_ID=your-pai-access-key-id
PAI_ACCESS_KEY_SECRET=your-pai-access-key-secret
# 临时 STS 凭证才需要填写；长期 AccessKey 留空。
PAI_SECURITY_TOKEN=
PAI_REGION_ID=cn-beijing
# 可留空使用 SDK 默认 endpoint；如需指定，示例：https://pai-dlc.cn-beijing.aliyuncs.com
PAI_DLC_ENDPOINT=
PAI_WORKSPACE_ID=your-pai-workspace-id
# 二选一：填写 PAI 资源组 ID，或填写 PAI_ECS_SPEC 使用公共资源规格。
PAI_RESOURCE_ID=
# 训练镜像完整地址，填写 ACR/公网镜像地址，不填写 PAI 自定义镜像 ID。
PAI_IMAGE_URI=registry.cn-beijing.aliyuncs.com/namespace/repository:tag
PAI_JOB_TYPE=PyTorchJob
PAI_ECS_SPEC=ecs.gn6v-c8g1.16xlarge
PAI_POD_COUNT=1
PAI_JOB_MAX_RUNNING_MINUTES=180
# PAI-DLC 中数据集、输出 OSS 与基础模型 OSS 挂载到容器内的目录。
PAI_DATASET_MOUNT_PATH=/mnt/dataset
PAI_OUTPUT_MOUNT_PATH=/mnt/output
PAI_BASE_MODEL_MOUNT_PATH=/mnt/base_model

# ── 远程训练 ACR 镜像认证配置 ───────────────────────────
# 公开镜像可留空；VPC 地址或私有镜像拉取失败时填写。
ACR_DOCKER_REGISTRY=
ACR_USERNAME=
ACR_PASSWORD=
