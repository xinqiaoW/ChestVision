# ═══════════════════════════════════════════════════════
# 胸片X光智能分析系统 — 环境变量配置
# ═══════════════════════════════════════════════════════

# ── OpenAI API 配置（根据项目需求进行修改使用） ─────────────────────────
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# ── Qwen API 配置 ───────────────────────────────────
QWEN_API_KEY=sk-your-qwen-api-key
QWEN_API_URL=https://dashscope.aliyuncs.com/api/v1/services/aigc/text-generation/generation
# Qwen 兼容模式 API（用于 LangChain OpenAI 客户端）
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ── 数据库配置 ───────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=your-database-name
DB_USER=your-database-username
DB_PASSWORD=your-database-password

# ── Redis 配置 ──────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# 开发环境：本地 Docker
DATABASE_URL=postgresql://your-database-username:your-database-password@localhost:5432/your-database-name
# 生产环境：取消下一行的注释并注释掉上面的行
# DATABASE_URL=postgresql://your-database-username:your-secure-password@your-host:5432/your-database-name

# ── 本地 LLM 配置（可选）────────────────────
USE_LOCAL_LLM=false
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b


# ── Redis 配置 ───────────────────────────────────────
# 开发环境：本地 Docker
REDIS_URL=redis://localhost:6379/0
# 生产环境：取消下一行的注释并注释掉上面的行
# REDIS_URL=redis://:your-redis-password@your-redis-host:6379/0

# ── MinIO 对象存储配置 ───────────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=your-minio-access-key
MINIO_SECRET_KEY=your-minio-secret-key
MINIO_BUCKET=chestx-agent-images
MINIO_SECURE=false

# ── JWT 认证配置 ─────────────────────────────────────
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── 应用配置 ─────────────────────────────────────────
APP_NAME=RSOD Agent Platform
APP_VERSION=0.1.0
DEBUG=true
LOG_LEVEL=INFO

# ── CORS 配置 ────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# ── 远程训练 OSS 配置 ───────────────────────────────────
# 服务端用于签发上传凭据、HeadObject 校验和读取训练产物。
# 可使用 OSS_* 独立凭证；如果留空，代码会尝试使用 ALIBABA_CLOUD_* 统一凭证。
OSS_ACCESS_KEY_ID=your-oss-access-key-id
OSS_ACCESS_KEY_SECRET=your-oss-access-key-secret
# 临时 STS 凭证才需要填写；长期 AccessKey 留空。
OSS_SECURITY_TOKEN=
# 普通 bucket 示例：https://oss-cn-beijing.aliyuncs.com
# 接入点 alias 场景下，这里仍填写地域 endpoint，不填写对象 URL 或预签名 URL。
OSS_ENDPOINT=https://oss-cn-beijing.aliyuncs.com
OSS_REGION=cn-beijing
# 普通 bucket 填 bucket 名；接入点场景填接入点 alias。
OSS_BUCKET=your-oss-bucket-or-access-point-alias
# 远程训练对象前缀，属于 bucket 内部路径。
REMOTE_TRAIN_OSS_PREFIX=remote-training
# 浏览器上传凭据有效期，单位秒；当前兼容 PUT 预签名 URL。
OSS_UPLOAD_URL_EXPIRES_SECONDS=900
# FC/EventBridge 调用后端内部回调接口的机器密钥；生产环境必须设置为随机长字符串。
REMOTE_TRAINING_CALLBACK_SECRET=change-me-to-a-random-secret

# ── 远程训练 PAI-DLC 配置 ───────────────────────────────
# 服务端用于创建、查询和停止 PAI-DLC 任务。
# 可使用 PAI_* 独立凭证；如果留空，代码会尝试使用 ALIBABA_CLOUD_* 统一凭证。
PAI_ACCESS_KEY_ID=your-pai-access-key-id
PAI_ACCESS_KEY_SECRET=your-pai-access-key-secret
# 临时 STS 凭证才需要填写；长期 AccessKey 留空。
PAI_SECURITY_TOKEN=
PAI_REGION_ID=cn-beijing
# 可留空使用 SDK 默认 endpoint；如需指定，示例：https://pai-dlc.cn-beijing.aliyuncs.com
PAI_DLC_ENDPOINT=
PAI_WORKSPACE_ID=your-pai-workspace-id
# 二选一：填写 PAI 资源组 ID，或填写 PAI_ECS_SPEC 使用公共资源规格。
PAI_RESOURCE_ID=
# 训练镜像完整地址，填写 ACR/公网镜像地址，不填写 PAI 自定义镜像 ID。
PAI_IMAGE_URI=registry.cn-beijing.aliyuncs.com/namespace/repository:tag
PAI_JOB_TYPE=PyTorchJob
PAI_ECS_SPEC=ecs.gn6v-c8g1.16xlarge
PAI_POD_COUNT=1
PAI_JOB_MAX_RUNNING_MINUTES=180
# PAI-DLC 中数据集与输出 OSS 挂载到容器内的目录。
PAI_DATASET_MOUNT_PATH=/mnt/dataset
PAI_OUTPUT_MOUNT_PATH=/mnt/output

# ── 远程训练 ACR 镜像认证配置 ───────────────────────────
# 公开镜像可留空；VPC 地址或私有镜像拉取失败时填写。
ACR_DOCKER_REGISTRY=
ACR_USERNAME=
ACR_PASSWORD=
